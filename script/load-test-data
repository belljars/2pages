#!/usr/bin/env bash
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
    _src="$(readlink "$_src")"
done
ROOT_DIR="$(cd "$(dirname "$_src")/.." && pwd)"

PYTHON="${PYTHON:-python3}"
ADD="$ROOT_DIR/src/app/add.py"
FIXTURES_DIR="$ROOT_DIR/test"

stdin_text="$("$PYTHON" - "$FIXTURES_DIR/hello.md" <<'PY'
import pathlib
import sys

print(pathlib.Path(sys.argv[1]).read_text().strip(), end="")
PY
)"

code_text="$("$PYTHON" - "$FIXTURES_DIR/hello.py" <<'PY'
import pathlib
import sys

print(pathlib.Path(sys.argv[1]).read_text(), end="__TWOPAGES_SENTINEL__")
PY
)"
code_text="${code_text%__TWOPAGES_SENTINEL__}"

printf '%s' "$stdin_text" | "$PYTHON" "$ADD"
"$PYTHON" "$ADD" --code "$code_text"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/test.json"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/bye.sh"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/bat.bat"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/birmingham-museums-trust-BPWZ01FtySg-unsplash.jpg"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/hm.mp4"

echo "loaded fixtures from $FIXTURES_DIR into $ROOT_DIR/archive.db"
