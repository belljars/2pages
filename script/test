#!/usr/bin/env bash
set -euo pipefail

_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
    _src="$(readlink "$_src")"
done
ROOT_DIR="$(cd "$(dirname "$_src")/.." && pwd)"

PYTHON="${PYTHON:-python3}"
ADD="$ROOT_DIR/src/app/add.py"
FIXTURES_DIR="$ROOT_DIR/test"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

export TWOPAGES_DB_PATH="$TMP_DIR/archive.db"

"$PYTHON" - "$ROOT_DIR" <<'PY'
import os
import sys

sys.path.insert(0, os.path.join(sys.argv[1], "src", "app"))
from db import init_db

init_db()
PY

stdin_text="$("$PYTHON" - "$FIXTURES_DIR/hello.md" <<'PY'
import pathlib
import sys

print(pathlib.Path(sys.argv[1]).read_text().strip(), end="")
PY
)"

code_text="$("$PYTHON" - "$FIXTURES_DIR/hello.py" <<'PY'
import pathlib
import sys

print(pathlib.Path(sys.argv[1]).read_text(), end="__TWOPAGES_SENTINEL__")
PY
)"
code_text="${code_text%__TWOPAGES_SENTINEL__}"

printf '%s' "$stdin_text" | "$PYTHON" "$ADD"
"$PYTHON" "$ADD" --code "$code_text"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/test.json"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/bye.sh"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/bat.bat"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/birmingham-museums-trust-BPWZ01FtySg-unsplash.jpg"
"$PYTHON" "$ADD" --file "$FIXTURES_DIR/hm.mp4"

"$PYTHON" - "$ROOT_DIR" <<'PY'
import base64
import mimetypes
import os
import sqlite3
import sys

root = sys.argv[1]
fixtures_dir = os.path.join(root, "test")
db_path = os.environ["TWOPAGES_DB_PATH"]

conn = sqlite3.connect(db_path)
conn.row_factory = sqlite3.Row
rows = conn.execute(
    "SELECT id, type, content, filename, mimetype FROM entries ORDER BY id"
).fetchall()

assert len(rows) == 7, f"expected 7 entries, found {len(rows)}"

expected = [
    {"type": "text", "path": os.path.join(fixtures_dir, "hello.md"), "mode": "text-stdin"},
    {"type": "code", "path": os.path.join(fixtures_dir, "hello.py"), "mode": "code"},
    {"type": "file", "path": os.path.join(fixtures_dir, "test.json"), "mode": "file"},
    {"type": "file", "path": os.path.join(fixtures_dir, "bye.sh"), "mode": "file"},
    {"type": "file", "path": os.path.join(fixtures_dir, "bat.bat"), "mode": "file"},
    {
        "type": "image",
        "path": os.path.join(fixtures_dir, "birmingham-museums-trust-BPWZ01FtySg-unsplash.jpg"),
        "mode": "file",
    },
    {"type": "video", "path": os.path.join(fixtures_dir, "hm.mp4"), "mode": "file"},
]

for index, (row, spec) in enumerate(zip(rows, expected), start=1):
    path = spec["path"]
    assert row["type"] == spec["type"], (
        f"entry {index}: expected type {spec['type']}, got {row['type']}"
    )
    if spec["mode"] == "text-stdin":
        expected_text = open(path, "r", encoding="utf-8").read().strip()
        assert row["content"] == expected_text, f"entry {index}: text content mismatch"
        assert row["filename"] is None, f"entry {index}: unexpected filename"
        assert row["mimetype"] is None, f"entry {index}: unexpected mimetype"
        continue
    if spec["mode"] == "code":
        expected_text = open(path, "r", encoding="utf-8").read()
        assert row["content"] == expected_text, f"entry {index}: code content mismatch"
        assert row["filename"] is None, f"entry {index}: unexpected filename"
        assert row["mimetype"] is None, f"entry {index}: unexpected mimetype"
        continue

    expected_mimetype, _ = mimetypes.guess_type(path)
    expected_mimetype = expected_mimetype or "application/octet-stream"
    assert row["filename"] == os.path.basename(path), (
        f"entry {index}: expected filename {os.path.basename(path)}, got {row['filename']}"
    )
    assert row["mimetype"] == expected_mimetype, (
        f"entry {index}: expected mimetype {expected_mimetype}, got {row['mimetype']}"
    )

    prefix = f"data:{expected_mimetype};base64,"
    assert row["content"].startswith(prefix), f"entry {index}: data URL prefix mismatch"
    encoded = row["content"][len(prefix):]
    actual_bytes = base64.b64decode(encoded)
    expected_bytes = open(path, "rb").read()
    assert actual_bytes == expected_bytes, f"entry {index}: file payload mismatch"

print(f"test passed: validated {len(rows)} entries using fixtures from {fixtures_dir}")
PY
